{
    "height": 20, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "modules-left": ["custom/logo", "hyprland/workspaces"],
    "modules-center": ["mpris"],
    "modules-right": ["custom/picker", "custom/separator", "bluetooth", "network", "pulseaudio",  "backlight", "battery", "clock"],

    "hyprland/window": {
        "format": "{}"
        
    },

    "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": true,
        "disable-scroll": true,
		"format": "{icon}",
		"on-click": "activate",
		"format-icons": {
        			// "1": "ΎΕΣ",
        			// "2": "ΎΕΣ",
        			// "3": "ΎΕΣ",
        			// "4": "ΎΕΣ",
        			// "5": "ΎΒΨ",
                    // "6": "ΎΕΣ",
        			// "7": "ΎΕΣ",
        			// "8": "ΎΕΣ",
        			// "9": "ΎΕΣ",
            "active": "ΎΕΣ",
			"urgent": "ΎΒς",
			"default": "ΎΕΣ",
    "sort-by-number": true
    },
    },

    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "tooltip": true,
        "format-alt": "<small>{percent}%</small>",
        "format-icons": ["≤▒σΟ ", "≤▒σΠ ", "≤▒σΡ ", "≤▒σΣ ", "≤▒σΤ ", "≤▒σΥ ", "≤▒σΦ ", "≤▒σΧ ", "≤▒σΨ ", "≤░δρ "],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "smooth-scrolling-threshold": "2400",
	"tooltip-format" : "Brightness {percent}%",
    },
    "network": {
        /* "format-wifi": "Ύςρ", */
        "format-wifi": "{icon}",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "≤░νφ",
        "tooltip-format": "{essid}",
        "interval": 1,
        "on-click": "~/.config/waybar/scripts/network/rofi-network-manager.sh",
        "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
        
    },
           "bluetooth": {
                "format": "{icon}",
                "interval": 30,
                "format-icons": {
                     "enabled": "ΎΛΦ",
                     "disabled": "≤░Γ▓"
                  
                },
                "on-click": "bluetooth toggle",
                "on-click-right": "exec blueman-manager",
                "tooltip-format": "{status}",
                "spacing": 10
           },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "≤░ΨΒ",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "≤░Χ╛"]
        },
        "on-click": "pamixer -t",
        "on-scroll-up": "pamixer -i 1",
        "on-scroll-down": "pamixer -d 1",
	"on-click-right": "exec pavucontrol",
        "tooltip-format" : "Volume {volume}%",
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} ",
      "format-warning": "{icon}",
      "format-critical": "{icon}",
      "format-charging": "<span font-family='Font Awesome 6 Free'>ΎΔπ</span>",
      "format-plugged": "≤░γξ", 
      "format-notcharging": "≤░γξ",
      "format-alt": "{icon}<small> {time}</small>",
      "format-full": "≤░ΓΕ", 
 

      "format-alt": "<small>{capacity}%</small> ",
      "format-full": "≤░γξ", 
      "format-icons": ["≤▒Λκ", "≤▒Λλ", "≤▒Λμ"]
    },

      "mpris": {
  	"format": " έΠ╕ <i>{title}</i>",
  	"format-paused": " έΨ╢ <i>{title}</i>",
    "interval" : 1 
  	// "ignored-players": ["firefox"]
  },
        
    "custom/logo": {
        "format": "≤▒ΕΖ",
        "on-click": "wlogout",
    },

    "custom/picker" : {
        "format": "ΎΘ╗",
        "on-click": "sleep .2; hyprpicker -a",
    },

    "custom/separator": {
        "format": "  ",
        "interval": "once",
        "tooltip": false
    },
}
